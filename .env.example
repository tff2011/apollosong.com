# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Next Auth
# You can generate a new secret on the command line with:
# npx auth secret
# https://next-auth.js.org/configuration/options#secret
AUTH_SECRET=""

# Next Auth Discord Provider
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Admin bootstrap (used to create/recover the first SUPER_ADMIN account)
ADMIN_EMAIL="admin@apollosong.com"
ADMIN_PASSWORD=""

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="postgresql://postgres:password@localhost:5432/apollosong.com"

# Redis
REDIS_URL="redis://localhost:6379"

# SMTP
SMTP_HOST=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="ApolloSong <no-reply@apollosong.com>"
SMTP_REPLY_TO=""
SMTP_SECURE="false"

# Site URL
NEXT_PUBLIC_SITE_URL="https://apollosong.com"

# Facebook Pixel
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=""
NEXT_PUBLIC_FACEBOOK_PIXEL_ID_2=""

# Facebook Conversions API
FACEBOOK_CAPI_ACCESS_TOKEN=""
FACEBOOK_CAPI_ACCESS_TOKEN_2=""

# TikTok Pixel
NEXT_PUBLIC_TIKTOK_PIXEL_ID=""

# TikTok Events API
TIKTOK_CAPI_ACCESS_TOKEN=""

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN=""
META_APP_SECRET=""
WHATSAPP_GRAPH_VERSION="v21.0"
# Optional: media TTL in minutes for /media uploads (mainly relevant for No Storage).
# Valid range: 60..43200. Set "0" to disable sending ttl_minutes.
WHATSAPP_MEDIA_TTL_MINUTES="43200"
# Optional safety switch. Keep "false" to avoid brittle audio.link fallback.
WHATSAPP_ENABLE_AUDIO_LINK_FALLBACK="false"

# =========================
# Suno Automation (Local)
# =========================
# Optional: pause Suno automation quickly
SUNO_AUTOMATION_ENABLED="true"

# Optional: Playwright / Suno browser settings
SUNO_HEADLESS="false"
SUNO_AUTH_STATE_PATH="./suno-auth-state.json"
SUNO_USER_DATA_DIR="./playwright-user-data"
SUNO_AUTH_STATE_TMP_PATH="/tmp/suno-auth-state.json"
# Optional: reduce bandwidth / speed up loads ("off" | "light" | "aggressive")
# - light: blocks images + fonts (safe)
# - aggressive: blocks images + fonts + media (may affect audio playback; downloads are allowed)
SUNO_RESOURCE_BLOCKING="off"
# Optional: reduce fixed waits / poll more often (does not change Suno generation time)
SUNO_FAST_MODE="false"
# Optional: disable long random pauses in FatigueManager (2-5 min)
SUNO_DISABLE_COFFEE_BREAKS="false"
# Optional: reduce false positives from short-lived captcha iframes
SUNO_CAPTCHA_DEBOUNCE_MS="1500"
# Optional: logs sanitized captcha iframe diagnostics
SUNO_DEBUG_CAPTCHA="false"
# Optional: auto screenshot when captcha is detected (cooldown avoids spam)
SUNO_CAPTCHA_AUTO_SCREENSHOT="true"
SUNO_CAPTCHA_SCREENSHOT_COOLDOWN_MS="60000"
# Optional: Telegram alert cooldown (avoid spam)
SUNO_CAPTCHA_ALERT_COOLDOWN_MS="120000"
# Optional: play a loud siren when a CAPTCHA is detected (best with SUNO_HEADLESS="false")
SUNO_CAPTCHA_SIREN="false"
SUNO_CAPTCHA_SIREN_DURATION_MS="6500"
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=""

# =========================
# Suno API (Kie.ai)
# =========================
# API-first generation in workers (falls back to browser automation if enabled/configured)
SUNO_KIE_ENABLED="true"
KIE_API_KEY=""
KIE_BASE_URL="https://api.kie.ai/api/v1"
KIE_SUNO_MODEL="V4_5"
# Optional callback endpoint (if you want Kie webhooks in parallel to polling)
KIE_CALLBACK_URL=""
# Optional label saved into SongOrder.sunoAccountEmail when Kie path is used
KIE_SUNO_ACCOUNT_EMAIL="kie-api"
# Optional: webhook signature verification key from Kie
KIE_WEBHOOK_HMAC_KEY=""
# Optional: max accepted clock skew for webhook timestamp verification
KIE_WEBHOOK_MAX_SKEW_SECONDS="300"
# Optional tuning
KIE_SUNO_POLL_INTERVAL_MS="3000"
KIE_SUNO_POLL_TIMEOUT_MS="1200000"
KIE_SUNO_HTTP_TIMEOUT_MS="60000"
# Rate limit guard (Kie docs: 20 generate requests / 10s per account)
KIE_SUNO_RATE_LIMIT_MAX="20"
KIE_SUNO_RATE_LIMIT_WINDOW_MS="10000"
